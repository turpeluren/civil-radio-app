{
  "name": "substreamer",
  "version": "8.0.23",
  "license": "GPL-3.0-or-later",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "source scripts/env-android.sh && expo run:android ${EXPO_ANDROID_DEVICE:+--device $EXPO_ANDROID_DEVICE}",
    "android:device": "source scripts/env-android.sh && expo run:android",
    "ios": "expo run:ios",
    "concurrent": "npx concurrently \"npm run ios\" \"npm run android\"",
    "prebuild": "expo prebuild --clean",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:modules": "scripts/test-modules.sh",
    "build:modules": "scripts/build-modules.sh",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=html",
    "generate-assets": "node scripts/generate-assets.js",
    "release": "node scripts/create-release.js",
    "release:patch": "node scripts/create-release.js patch",
    "release:minor": "node scripts/create-release.js minor",
    "release:major": "node scripts/create-release.js major"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-community/slider": "5.1.2",
    "@react-native-picker/picker": "^2.11.4",
    "@shopify/flash-list": "^2.3.0",
    "expo": "^55.0.5",
    "expo-async-fs": "file:./modules/expo-async-fs",
    "expo-backup-exclusions": "file:./modules/expo-backup-exclusions",
    "expo-build-properties": "~55.0.9",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.9",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-gzip": "file:./modules/expo-gzip",
    "expo-haptics": "~55.0.8",
    "expo-image-manipulator": "~55.0.9",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-location": "~55.1.2",
    "expo-notifications": "~55.0.11",
    "expo-router": "~55.0.4",
    "expo-sqlite": "~55.0.10",
    "expo-ssl-trust": "file:./modules/expo-ssl-trust",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^12.2.0",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-bootsplash": "^7.1.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-image-colors": "^2.5.1",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "15.15.3",
    "react-native-track-player": "file:./modules/react-native-track-player",
    "react-native-worklets": "0.7.4",
    "subsonic-api": "^3.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.10",
    "expo-dev-client": "^55.0.11",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.9",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@react-native-community/netinfo",
        "@react-native-picker/picker",
        "@shopify/flash-list",
        "react-native-bootsplash",
        "react-native-gesture-handler",
        "react-native-reanimated",
        "react-native-safe-area-context",
        "react-native-screens",
        "react-native-worklets"
      ]
    },
    "doctor": {
      "dependencies": {
        "exclude": [
          "@react-native-community/netinfo",
          "react-native-safe-area-context"
        ]
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-track-player",
          "expo-async-fs",
          "expo-ssl-trust",
          "expo-backup-exclusions",
          "expo-gzip"
        ]
      }
    }
  }
}
