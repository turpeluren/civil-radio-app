default_platform(:ios)

def asc_api_key
  params = {
    key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"]
  }
  # CI passes key content directly; local dev uses a file path
  if ENV["APP_STORE_CONNECT_API_KEY_KEY"]
    params[:key_content] = ENV["APP_STORE_CONNECT_API_KEY_KEY"]
  else
    params[:key_filepath] = ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
  end
  app_store_connect_api_key(params)
end

platform :ios do
  desc "Push App Store metadata and screenshots"
  lane :metadata do
    require 'fileutils'
    require 'json'
    api_key = asc_api_key
    project_root = File.expand_path("..")
    source_path = File.join(project_root, "fastlane", "metadata", "ios")
    push_path = File.join(project_root, "fastlane", ".metadata_push")

    # Prepare metadata: strip app-info level fields (only editable during app info review)
    FileUtils.rm_rf(push_path)
    FileUtils.cp_r(source_path, push_path)
    %w[name.txt subtitle.txt privacy_url.txt].each do |file|
      Dir.glob("#{push_path}/**/#{file}").each { |f| File.delete(f) }
    end

    # Check if an editable version already exists
    app = Spaceship::ConnectAPI::App.find("com.ghenry22.substream2")
    edit_version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)

    deliver_params = {
      api_key: api_key,
      app_identifier: "com.ghenry22.substream2",
      skip_binary_upload: true,
      force: true,
      submit_for_review: false,
      precheck_include_in_app_purchases: false,
      metadata_path: push_path,
      screenshots_path: File.join(project_root, "fastlane", "screenshots")
    }

    # Review contact info from env vars (not stored in repo — public repo)
    if ENV["APP_REVIEW_FIRST_NAME"]
      deliver_params[:app_review_information] = {
        first_name: ENV["APP_REVIEW_FIRST_NAME"],
        last_name: ENV["APP_REVIEW_LAST_NAME"],
        email_address: ENV["APP_REVIEW_EMAIL"],
        phone_number: ENV["APP_REVIEW_PHONE"]
      }
    end

    if edit_version
      UI.message("Found editable version #{edit_version.version_string} — pushing metadata")
      deliver_params[:skip_app_version_update] = true
    else
      # Create a new editable version using the app version from app.json
      app_json = JSON.parse(File.read(File.join(project_root, "app.json")))
      app_version = app_json.dig("expo", "version")
      UI.message("No editable version found — creating version #{app_version} and pushing metadata")
      deliver_params[:app_version] = app_version
    end

    deliver(deliver_params)
  ensure
    FileUtils.rm_rf(push_path) if defined?(push_path) && push_path
  end

  desc "Pull current App Store metadata into local files"
  lane :pull_metadata do
    require 'json'
    project_root = File.expand_path("..")
    api_key_path = File.join(project_root, "fastlane", ".api_key.json")
    key_content = File.read(File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"], project_root))
    File.write(api_key_path, JSON.pretty_generate({
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key: key_content,
      in_house: false
    }))
    begin
      sh("fastlane deliver download_metadata " \
         "--app_identifier com.ghenry22.substream2 " \
         "--metadata_path ./metadata/ios " \
         "--use_live_version true " \
         "--api_key_path #{api_key_path}")
    ensure
      File.delete(api_key_path) if File.exist?(api_key_path)
    end
    UI.success("iOS metadata downloaded to fastlane/metadata/ios/")
  end
end

platform :android do
  desc "Push Play Store metadata and screenshots"
  lane :metadata do
    supply(
      package_name: "com.ghenry22.substream2",
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      skip_upload_changelogs: true,
      metadata_path: "./fastlane/metadata/android",
      track: "beta"
    )
  end

  desc "Pull current Play Store metadata into local files"
  lane :pull_metadata do
    project_root = File.expand_path("..")
    json_key = File.expand_path(ENV["SUPPLY_JSON_KEY_FILE"], project_root)
    sh("fastlane supply init " \
       "--package_name com.ghenry22.substream2 " \
       "--metadata_path ./metadata/android " \
       "--json_key #{json_key} " \
       "--track beta")
    UI.success("Android metadata downloaded to fastlane/metadata/android/")
  end
end
