# Copy this file to .env and fill in your values
# cp .env-template .env

FASTLANE_OPT_OUT_USAGE=1
FASTLANE_SKIP_DOCS=1

# App Store Connect API Key
# Generate at: App Store Connect > Users and Access > Integrations > App Store Connect API
APP_STORE_CONNECT_API_KEY_KEY_ID=your-key-id
APP_STORE_CONNECT_API_KEY_ISSUER_ID=your-issuer-id
APP_STORE_CONNECT_API_KEY_KEY_FILEPATH=./fastlane/app-store-connect-key.p8

# Google Play Service Account
# Create at: Google Cloud Console > Service Accounts
# Invite service account email in Play Console > Users and Permissions
# Grant App permissions > Store presence > Manage store presence
SUPPLY_JSON_KEY_FILE=./fastlane/play-store-key.json

# App Review Contact Info (only visible to Apple reviewers, not public)
APP_REVIEW_FIRST_NAME=your-first-name
APP_REVIEW_LAST_NAME=your-last-name
APP_REVIEW_EMAIL=your-email
APP_REVIEW_PHONE=+1-xxx-xxx-xxxx
