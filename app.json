{
  "expo": {
    "name": "substreamer",
    "slug": "substreamer",
    "version": "8.0.27",
    "scheme": "substreamer",
    "platforms": [
      "android",
      "ios"
    ],
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.ghenry22.substream2",
      "buildNumber": "111",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Location access is needed to detect your WiFi network name for automatic offline mode switching."
      },
      "entitlements": {
        "com.apple.developer.networking.wifi-info": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#1D9BF0"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ],
      "predictiveBackGestureEnabled": false,
      "versionCode": 80000111,
      "package": "com.ghenry22.substream2"
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-bootsplash",
        {
          "logo": "./src/assets/splash-logo.svg",
          "logoWidth": 130,
          "background": "#1D9BF0"
        }
      ],
      "./plugins/silence-hermes-warning",
      "./plugins/silence-dev-launcher-warning",
      "./plugins/dedupe-lc++",
      "./plugins/fix-jvm-target",
      "./plugins/set-gradle-version",
      "expo-sqlite",
      "./modules/expo-ssl-trust/plugin",
      "./modules/expo-backup-exclusions/plugin",
      "./modules/react-native-track-player/plugin",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 29,
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "-keep class expo.modules.** { *; }\n-keep class com.doublesymmetry.** { *; }"
          }
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": false,
          "isIosBackgroundLocationEnabled": false
        }
      ],
      "./plugins/strip-push-entitlement",
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b3c7e72f-f01c-4110-8a30-a669b1d9bf34"
      }
    },
    "owner": "ghenry22"
  }
}
