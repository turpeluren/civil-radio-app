{
  "expo": {
    "name": "substreamer",
    "slug": "substreamer",
    "version": "8.0.8",
    "scheme": "substreamer",
    "platforms": [
      "android",
      "ios"
    ],
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.ghenry22.substream2",
      "buildNumber": "92",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#1D9BF0"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 92,
      "package": "com.ghenry22.substream2"
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-bootsplash",
        {
          "logo": "./src/assets/splash-logo.svg",
          "logoWidth": 130,
          "background": "#1D9BF0"
        }
      ],
      "./plugins/silence-hermes-warning",
      "./plugins/fix-jvm-target",
      "expo-sqlite",
      "./modules/expo-ssl-trust/plugin",
      "./modules/expo-backup-exclusions/plugin",
      "./modules/react-native-track-player/plugin",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b3c7e72f-f01c-4110-8a30-a669b1d9bf34"
      }
    },
    "owner": "ghenry22"
  }
}
